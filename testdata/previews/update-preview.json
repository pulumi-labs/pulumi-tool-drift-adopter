{
  "steps": [
    {
      "op": "update",
      "urn": "urn:pulumi:dev::myapp::aws:s3/bucket:Bucket::my-bucket",
      "type": "aws:s3/bucket:Bucket",
      "old": {
        "inputs": {
          "bucket": "my-bucket",
          "tags": {
            "Environment": "dev"
          }
        }
      },
      "new": {
        "inputs": {
          "bucket": "my-bucket",
          "tags": {
            "Environment": "production"
          }
        }
      },
      "diffs": ["tags.Environment"],
      "detailedDiff": {
        "tags.Environment": {
          "kind": "update",
          "inputDiff": true,
          "lhs": "dev",
          "rhs": "production"
        }
      }
    }
  ]
}
